{
  "$schema": "https://opencode.ai/config.json",

  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "chrome-devtools-mcp",
        "--browser-url=http://127.0.0.1:9222",
        "--no-usage-statistics",
        "--no-performance-crux",
        "--redact-network-headers"
      ],
      "enabled": true,
      "timeout": 10000
    }
  }
}